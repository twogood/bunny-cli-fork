{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "app": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "scaling": {
          "type": "object",
          "properties": {
            "min": {
              "type": "number"
            },
            "max": {
              "type": "number"
            }
          },
          "required": ["min", "max"],
          "additionalProperties": false
        },
        "regions": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "object",
              "properties": {
                "allowed": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "required": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "containers": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "image": {
                "type": "string"
              },
              "dockerfile": {
                "type": "string"
              },
              "context": {
                "type": "string"
              },
              "command": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "registry": {
                "type": "string"
              },
              "env": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              },
              "probes": {
                "type": "object",
                "properties": {
                  "readiness": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": ["http", "tcp", "grpc"]
                      },
                      "path": {
                        "type": "string"
                      },
                      "port": {
                        "type": "number"
                      }
                    },
                    "required": ["type"],
                    "additionalProperties": false
                  },
                  "liveness": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": ["http", "tcp", "grpc"]
                      },
                      "path": {
                        "type": "string"
                      },
                      "port": {
                        "type": "number"
                      }
                    },
                    "required": ["type"],
                    "additionalProperties": false
                  },
                  "startup": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": ["http", "tcp", "grpc"]
                      },
                      "path": {
                        "type": "string"
                      },
                      "port": {
                        "type": "number"
                      }
                    },
                    "required": ["type"],
                    "additionalProperties": false
                  }
                },
                "additionalProperties": false
              },
              "endpoints": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["cdn", "anycast"]
                    },
                    "ssl": {
                      "type": "boolean"
                    },
                    "ports": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "public": {
                            "type": "number"
                          },
                          "container": {
                            "type": "number"
                          }
                        },
                        "required": ["public", "container"],
                        "additionalProperties": false
                      }
                    }
                  },
                  "required": ["type"],
                  "additionalProperties": false
                }
              },
              "volumes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "mount": {
                      "type": "string"
                    },
                    "size": {
                      "type": "number"
                    }
                  },
                  "required": ["name", "mount", "size"],
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "required": ["name", "containers"],
      "additionalProperties": false
    }
  },
  "required": ["version", "app"],
  "additionalProperties": false
}
