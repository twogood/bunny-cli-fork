{
  "name": "@bunny.net/openapi-client",
  "version": "0.0.1",
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "generate": "openapi-typescript",
    "update-specs": "bun run scripts/update-specs.ts && bun run generate"
  },
  "exports": {
    ".": "./src/index.ts",
    "./generated/*": "./src/generated/*"
  },
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0"
  }
}
